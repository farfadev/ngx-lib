{
  "name": "ngx-lib",
  "version": "0.0.0",
  "scripts": {
    "start": "npm-run-all clean --parallel lib:watch showcase:start-waiton",
    "build": "run-s lib:build showcase:build",
    "lib-oe:publish": "ng build @farfadev/ngx-object-editor --configuration production && cd ./dist/farfadev/ngx-object-editor && npm publish --access public",
    "lib-at:publish": "ng build @farfadev/ngx-a-tooltip --configuration production && cd ./dist/farfadev/ngx-a-tooltip && npm publish --access public",
    "lib-svg:publish": "ng build @farfadev/ngx-svg --configuration production && cd ./dist/farfadev/ngx-svg && npm publish --access public",
    "lib:build": "run-s lib:build-at lib:build-svg lib:build-oe",
    "lib:build-svg": "ng build @farfadev/ngx-svg",
    "lib:build-at": "ng build @farfadev/ngx-a-tooltip",
    "lib:build-oe": "ng build @farfadev/ngx-object-editor",
    "lib:watch": "run-p lib:watch-at lib:watch-svg lib:watch-oe",
    "lib:watch-svg": "ng build @farfadev/ngx-svg --watch --configuration development",
    "lib:watch-at": "ng build @farfadev/ngx-a-tooltip --watch --configuration development",
    "lib:watch-oe": "wait-on dist/farfadev/ngx-a-tooltip/package.json && wait-on dist/farfadev/ngx-svg/package.json && ng build @farfadev/ngx-object-editor --watch --configuration development",
    "lib:test": "ng test @farfadev/ngx-object-editor",
    "showcase:start-waiton": "wait-on dist/farfadev/ngx-object-editor/package.json && wait 2000 && npm run showcase:start",
    "showcase:start": "npm run showcase:copy-assets && ng serve showcase",
    "showcase:build": "ng build showcase",
    "showcase:watch": "ng build showcase --watch --configuration development",
    "showcase:test": "ng test showcase",
    "showcase:copy-assets": "rimraf projects/showcase/public/assets/showcases && npx copyfiles -u 4 \"projects/showcase/src/app/showcases/**/*\" projects/showcase/public/assets",
    "clean": "ng cache clean && rimraf dist"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@primeng/themes": "^21.0.3",
    "decimal.js": "^10.5.0",
    "highlight.js": "^11.11.1",
    "imask": "^7.6.1",
    "lodash-es": "^4.17.21",
    "mathjs": "^14.3.1",
    "rxjs": "~7.8.0",
    "tslib": ">=2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/dom": "^10.4.1",
    "@types/lodash-es": "^4.17.12",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.0.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "copyfiles": "^2.4.1",
    "jsdom": "^29.0.2",
    "ng-packagr": "^21.2.3",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.2",
    "vitest-browser-angular": "^0.4.0",
    "wait": "^0.4.2",
    "wait-on": "^8.0.2"
  }
}